      "parameters": {
        "jsCode": "const linhas = $input.all();\n\nconst contexto = linhas.map(item => `\nCategoria: ${item.json.categoria}\nTítulo: ${item.json.titulo}\nConteúdo: ${item.json.conteudo}\nTags: ${item.json.tags}\n`).join(\"\\n-----------------------------\\n\");\n\n// Recupera os dados do Edit Fields\nconst edit = $(\"Edit Fields\").first().json;\n\nreturn [{\n  json: {\n    pergunta_usuario: edit.pergunta_usuario,\n    mensagem: edit.mensagem,\n    idioma: edit.idioma,\n    usuario: edit.usuario,\n    especialidade: edit.especialidade,\n    contexto\n  }\n}];"
